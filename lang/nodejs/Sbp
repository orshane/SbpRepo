PORTNAME=nodejs
VERSION=22.15.0
FETCH_CMD=curl -L https://nodejs.org/dist/v22.15.0/node-v22.15.0.tar.xz -o /usr/local/var/sbpi/distfiles/node-22.15.0.tar.xz
BUILD_CMD=tar -xJf /usr/local/var/sbpi/distfiles/node-22.15.0.tar.xz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/node-v22.15.0 && ./configure --prefix=/usr/local && make -j$(nproc)
INSTALL_CMD=cd /usr/local/var/sbpi/work/node-v22.15.0 && sudo make install
UNINSTALL_CMD=sudo rm -f /usr/local/bin/node /usr/local/bin/npm /usr/local/bin/npx && sudo rm -rf /usr/local/lib/node_modules
