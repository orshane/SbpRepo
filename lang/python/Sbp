PORTNAME=python
VERSION=3.13.3
FETCH_CMD=curl -L https://www.python.org/ftp/python/3.13.3/Python-3.13.3.tar.xz -o /usr/local/var/sbpi/distfiles/python-3.13.3.tar.xz
BUILD_CMD=tar -xJf /usr/local/var/sbpi/distfiles/python-3.13.3.tar.xz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/Python-3.13.3 && ./configure --prefix=/usr/local --enable-optimizations --with-lto && make -j$(nproc)
INSTALL_CMD=cd /usr/local/var/sbpi/work/Python-3.13.3 && sudo make altinstall
UNINSTALL_CMD=sudo rm -f /usr/local/bin/python3.13 /usr/local/bin/pip3.13 && sudo rm -rf /usr/local/lib/python3.13
