PORTNAME=zig
VERSION=0.16.0
FETCH_CMD=curl -L https://codeberg.org/ziglang/zig/archive/0.16.0.tar.gz -o /usr/local/var/sbpi/distfiles/zig-0.16.0.tar.gz
BUILD_CMD=tar -xzf /usr/local/var/sbpi/distfiles/zig-0.16.0.tar.gz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/zig && mkdir build && cd build && cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr/local && make -j$(nproc)
INSTALL_CMD=cd /usr/local/var/sbpi/work/zig/build && sudo make install
UNINSTALL_CMD=sudo rm -f /usr/local/bin/zig && sudo rm -rf /usr/local/lib/zig
