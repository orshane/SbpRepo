PORTNAME=emacs
VERSION=30.1
FETCH_CMD=curl -L https://ftp.gnu.org/gnu/emacs/emacs-30.1.tar.xz -o /usr/local/var/sbpi/distfiles/emacs-30.1.tar.xz
BUILD_CMD=tar -xJf /usr/local/var/sbpi/distfiles/emacs-30.1.tar.xz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/emacs-30.1 && ./configure --prefix=/usr/local --without-x && make -j$(nproc)
INSTALL_CMD=cd /usr/local/var/sbpi/work/emacs-30.1 && sudo make install
UNINSTALL_CMD=sudo rm -f /usr/local/bin/emacs && sudo rm -rf /usr/local/share/emacs
