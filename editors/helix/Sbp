PORTNAME=helix
VERSION=25.01.1
FETCH_CMD=curl -L https://github.com/helix-editor/helix/archive/refs/tags/25.01.1.tar.gz -o /usr/local/var/sbpi/distfiles/helix-25.01.1.tar.gz
BUILD_CMD=tar -xzf /usr/local/var/sbpi/distfiles/helix-25.01.1.tar.gz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/helix-25.01.1 && cargo build --release
INSTALL_CMD=cd /usr/local/var/sbpi/work/helix-25.01.1 && sudo cp target/release/hx /usr/local/bin/hx && sudo mkdir -p /usr/local/share/helix && sudo cp -r runtime /usr/local/share/helix/
UNINSTALL_CMD=sudo rm -f /usr/local/bin/hx && sudo rm -rf /usr/local/share/helix
