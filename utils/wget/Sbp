PORTNAME=wget
VERSION=1.25.0
FETCH_CMD=curl -L https://ftp.gnu.org/gnu/wget/wget-1.25.0.tar.gz -o /usr/local/var/sbpi/distfiles/wget-1.25.0.tar.gz
BUILD_CMD=tar -xzf /usr/local/var/sbpi/distfiles/wget-1.25.0.tar.gz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/wget-1.25.0 && ./configure --prefix=/usr/local && make -j$(nproc)
INSTALL_CMD=cd /usr/local/var/sbpi/work/wget-1.25.0 && sudo make install
UNINSTALL_CMD=sudo rm -f /usr/local/bin/wget
