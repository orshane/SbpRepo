PORTNAME=fzf
VERSION=0.61.1
FETCH_CMD=curl -L https://github.com/junegunn/fzf/archive/refs/tags/v0.61.1.tar.gz -o /usr/local/var/sbpi/distfiles/fzf-0.61.1.tar.gz
BUILD_CMD=tar -xzf /usr/local/var/sbpi/distfiles/fzf-0.61.1.tar.gz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/fzf-0.61.1 && go build -o fzf .
INSTALL_CMD=cd /usr/local/var/sbpi/work/fzf-0.61.1 && sudo cp fzf /usr/local/bin/fzf
