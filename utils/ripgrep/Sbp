PORTNAME=ripgrep
VERSION=14.1.1
FETCH_CMD=curl -L https://github.com/BurntSushi/ripgrep/archive/refs/tags/14.1.1.tar.gz -o /usr/local/var/sbpi/distfiles/ripgrep-14.1.1.tar.gz
BUILD_CMD=tar -xzf /usr/local/var/sbpi/distfiles/ripgrep-14.1.1.tar.gz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/ripgrep-14.1.1 && cargo build --release
INSTALL_CMD=cd /usr/local/var/sbpi/work/ripgrep-14.1.1 && sudo cp target/release/rg /usr/local/bin/rg
UNINSTALL_CMD=sudo rm -f /usr/local/bin/rg
