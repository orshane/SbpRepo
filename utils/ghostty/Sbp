PORTNAME=ghostty
VERSION=1.1.3
FETCH_CMD=curl -L https://github.com/ghostty-org/ghostty/archive/refs/tags/v1.1.3.tar.gz -o /usr/local/var/sbpi/distfiles/ghostty-1.1.3.tar.gz
BUILD_CMD=tar -xzf /usr/local/var/sbpi/distfiles/ghostty-1.1.3.tar.gz -C /usr/local/var/sbpi/work && cd /usr/local/var/sbpi/work/ghostty-1.1.3 && zig build -p /usr/local -Doptimize=ReleaseFast
INSTALL_CMD=cd /usr/local/var/sbpi/work/ghostty-1.1.3 && sudo zig build install -p /usr/local -Doptimize=ReleaseFast
UNINSTALL_CMD=sudo rm -f /usr/local/bin/ghostty && sudo rm -rf /usr/local/share/ghostty
